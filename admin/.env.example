# Admin UI (Vite) — optional local overrides (do not commit secrets).

# ── Local dev (`cd admin && npm run dev`) ──
# Leave API vars unset → browser calls `/api/...` on :5174 → Vite proxies to backend (default http://127.0.0.1:3000).
# If your API runs elsewhere, set:
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:4000

# ── Production build (standalone admin on another domain) ──
# Prefer same variable as frontend (`frontend/.env.production`):
# VITE_API_URL=https://master-watch-yv9c.vercel.app
# Legacy names still work:
# VITE_API_BASE=https://your-backend.vercel.app
# VITE_PUBLIC_API_URL=https://your-backend.vercel.app

# Monolith (API serves /admin from same host): leave both unset → relative `/api/...`.

# Express mounts admin at /admin (not Vercel): see vite.config.js — default base is /admin/
# VITE_ADMIN_BASE=/admin/
