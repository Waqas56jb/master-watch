# Admin UI (Vite) — local & Vercel when Root Directory = `admin`

# IMPORTANT: VITE_API_BASE must be the Node/API deployment URL, NOT this admin site’s URL.
# If you omit it (or set it to the same origin as the admin app), requests use `/api/...` and
# `admin/vercel.json` rewrites those to your real backend — edit that file’s destination to match.

# Direct API calls (optional if you use the vercel.json /api proxy):
# VITE_API_BASE=https://master-watch-1zeu.vercel.app

# DO NOT set VITE_ADMIN_BASE on the Vercel admin project — VERCEL=1 makes Vite use base=/ so assets load from /assets/.
# Only local dev (Express mounts app at /admin) may use VITE_ADMIN_BASE=/admin/ in .env (optional).
# VITE_ADMIN_BASE=/admin/

# When you run `npm run dev` and use the Node server that mounts /admin, leave VITE_API_BASE empty so
# requests use same-origin /api/... (or Vite proxy).
