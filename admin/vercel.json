{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "build": {
    "env": {
      "VITE_ADMIN_BASE": "/"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
