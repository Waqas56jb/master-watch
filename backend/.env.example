# ── Copy to `.env` and fill secrets (never commit `.env`).
# ── On Vercel: add each key below in Dashboard → Settings → Environment Variables (never upload `.env`).
# ⚠ Rotate keys/passwords if they were pasted in chat or leaked.
# OpenAI (chat replies)
OPENAI_API_KEY=

# ── Postgres: Supabase
# Project ref: ybudqoutarcajsltczvk
# Password: special chars must be URL-encoded in the URI (e.g. ! → %21)
# Get string: Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD_HERE@db.ybudqoutarcajsltczvk.supabase.co:5432/postgres

# Vercel / serverless: prefer the Transaction pooler URI (port 6543) + ?pgbouncer=true — more reliable than
# db.*.supabase.co:5432 when IPv6 or long-lived connections are an issue. Copy from Supabase → Connect → ORMs / Transaction pooler.
# DATABASE_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional: set DATABASE_IPV4_FIRST=false only if you must force default DNS order (rare).
# Code sets dns.setDefaultResultOrder('ipv4first') so direct db host resolves to IPv4 when possible.

# Vercel: set DATABASE_URL and JWT_SECRET (≥16 chars) on the backend project.

# Optional smoke tests: npm run verify-api [baseUrl] — or set API_BASE_URL, ADMIN_TEST_EMAIL, ADMIN_TEST_PASSWORD
# API_BASE_URL=https://your-deployment.vercel.app

# JWT for admin REST API (≥16 chars; use a long random string in prod)
JWT_SECRET=change-this-to-a-long-random-string-min-16-chars
# Must be a valid jsonwebtoken duration, e.g. 7d, 24h, 3600 — invalid values fall back to 7d in code.
JWT_EXPIRES=7d

# Optional: add on Vercel temporarily to return error `detail`/`code` in JSON for 500s (login, health db).
# API_DEBUG=1

# First run (creates tables): npm run db:apply
# Supabase Dashboard → paste schema.sql manually if CLI fails.

# ── Optional CLI only: `npm run seed-admin` (creates/updates ONE row in admin_users).
# The running server and admin login do NOT read ADMIN_EMAIL / ADMIN_PASSWORD — only the DB does.
# Omit these on Vercel; run seed from your machine with DATABASE_URL when you need the first admin.
# Or set in .env temporarily:
#   ADMIN_EMAIL=you@domain.com
#   ADMIN_PASSWORD=your-strong-password
# (Quote password if it has shell-special chars: ADMIN_PASSWORD="p#ss!")

# Passwort-Reset (Admin-UI): Schritt 1 prüft E-Mail in admin_users; Schritt 2 nutzt kurzlebigen Token (JWT_SECRET).
# Optional Supabase REST/JS SDK
SUPABASE_URL=https://ybudqoutarcajsltczvk.supabase.co
# Dashboard → Settings → API → anon (public)
SUPABASE_ANON_KEY=paste_anon_jwt_here
# Dashboard → Settings → API → service_role — server only, never expose to browsers
SUPABASE_SERVICE_ROLE_KEY=paste_service_role_jwt_here

# Optional publishable keys (some Supabase tools use these instead of JWT)
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SECRET_KEY=

# Optional CORS (comma-separated origins)
# CORS is open to all origins by default. The line below is unused unless you re-add a whitelist in server.js.
# ALLOWED_ORIGINS=https://your-chat.vercel.app,https://your-admin.vercel.app

# Supabase needs TLS. Do not set to false against Supabase.
# DATABASE_SSL=false
